#!/usr/bin/env python3
# run - build and run a simulation test (or regression) with Verilator
#
# Usage: scripts/run [options] <testname|regressname>
#
# Single test:
#   scripts/run test_cpu_bringup_basic
#   scripts/run --trace test_cpu_bringup_basic
#   scripts/run -j 4 test_cpu_bringup_basic      # Verilator multithreaded
#
# Regression (name must start with regress_):
#   scripts/run regress_cpu_bringup
#   scripts/run regress_cpu_bringup -j 4         # run 4 tests in parallel
#   scripts/run --trace regress_cpu_bringup
#
# The script will:
#   1. Find <testname>.svh (new style) or <testname>.sv (legacy) under tb/
#   2. For .svh tests: read tb/cpu/bringup/template/bringup_wrapper.sv.tmpl,
#      substitute %%TESTNAME%%, and write a generated top module to rundir/
#   3. Resolve the source filelist (.f): per-test if present, else hdl/cpu/top/cpu.f
#   4. Expand path variables in the filelist
#   5. Compile with Verilator into rundir/<testname>/work/
#   6. Run the simulation (outputs, waveform.vcd land in rundir/<testname>/)
#
# Regression mode reads a <regressname>.list file from tb/, runs each listed
# test, and places outputs under rundir/<regressname>/<testname>/.
# With -j N, up to N tests run in parallel (1 core per test); output for each
# test is captured to rundir/<regressname>/<testname>/run.log.

import argparse
import concurrent.futures
import os
import re
import subprocess
import sys
import threading

# ---------------------------------------------------------------------------
# Locate repo root (one level up from this script)
# ---------------------------------------------------------------------------
script_dir = os.path.dirname(os.path.abspath(__file__))
repo_root  = os.path.dirname(script_dir)

# ---------------------------------------------------------------------------
# Defaults
# ---------------------------------------------------------------------------
DEFAULT_REGRESS_JOBS = 2   # parallel tests when -j is not specified in regression mode

# ---------------------------------------------------------------------------
# Parse arguments
# ---------------------------------------------------------------------------
parser = argparse.ArgumentParser(
    usage='%(prog)s [--trace] [-j N] <testname|regressname> [-- <verilator-args>...]'
)
parser.add_argument('--trace', action='store_true')
parser.add_argument('-j', type=int, metavar='N', default=None,
                    help='Single-test: Verilator thread count (default 1). '
                         f'Regression: parallel test count (default {DEFAULT_REGRESS_JOBS}).')
parser.add_argument('name', help='Test name or regression list name (regress_* prefix triggers regression mode)')
args, extra_verilator_args = parser.parse_known_args()

is_regress = args.name.startswith('regress_')
jobs = args.j if args.j is not None else (DEFAULT_REGRESS_JOBS if is_regress else 1)

if jobs < 1:
    sys.exit("ERROR: -j must be >= 1")

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def find_tb_file(testname):
    """Search tb/ for <testname>.svh (preferred) or <testname>.sv (legacy)."""
    tb_file    = None
    test_style = None
    for dirpath, _dirnames, filenames in os.walk(os.path.join(repo_root, 'tb')):
        if tb_file:
            break
        for fname in filenames:
            if fname == f'{testname}.svh':
                tb_file    = os.path.join(dirpath, fname)
                test_style = 'svh'
                break
            elif fname == f'{testname}.sv' and tb_file is None:
                tb_file    = os.path.join(dirpath, fname)
                test_style = 'sv'
    return tb_file, test_style


vars_ = {
    'CPU_DIR'       : os.path.join(repo_root, 'hdl', 'cpu'),
    'COMMON_DIR'    : os.path.join(repo_root, 'hdl', 'common'),
    'CHIPLEVEL_DIR' : os.path.join(repo_root, 'hdl', 'chiplevel'),
}

def expand_vars(line):
    def replace(m):
        key = m.group(1)
        if key in vars_:
            return vars_[key]
        sys.exit(f"Unknown variable ${key} in filelist")
    return re.sub(r'\$\{(\w+)\}', replace, line)


def run_test(testname, run_dir, trace, threads=1, log=None, extra_verilator_args=None):
    """Build and simulate a single test, placing outputs in run_dir.

    threads: passed as --threads to Verilator (single-test mode).
    log:     open file object; when set, all output (prints + subprocess)
             goes there instead of stdout. Used in parallel regression.
    """
    def emit(msg=''):
        print(msg, file=log) if log else print(msg)

    def run_cmd(cmd, **kwargs):
        if log:
            return subprocess.run(cmd, stdout=log, stderr=log, **kwargs)
        return subprocess.run(cmd, **kwargs)

    # Find testbench file
    tb_file, test_style = find_tb_file(testname)
    if tb_file is None:
        raise RuntimeError(
            f"could not find '{testname}.svh' or '{testname}.sv' under {repo_root}/tb"
        )
    emit(f"testbench : {tb_file}  ({test_style})")

    # Output directories
    work_dir = os.path.join(run_dir, 'work' + ('_trace' if trace else ''))
    os.makedirs(work_dir, exist_ok=True)

    # Auto-assemble: if a same-named .s file sits next to the .svh, assemble it
    # and place the .hex in run_dir so the test can reference it by name only.
    asm_file = os.path.join(os.path.dirname(tb_file), f'{testname}.s')
    if os.path.isfile(asm_file):
        hex_out = os.path.join(run_dir, f'{testname}.hex')
        emit(f"assemble  : {os.path.relpath(asm_file)} → {os.path.relpath(hex_out)}")
        assemble_script = os.path.join(script_dir, 'assemble')
        result = run_cmd([sys.executable, assemble_script, asm_file, '--out', hex_out])
        if result.returncode != 0:
            raise RuntimeError(f"Assembly failed for {asm_file}")

    # Generate wrapper (svh) or use file directly (sv)
    if test_style == 'svh':
        tests_dir   = os.path.dirname(tb_file)
        bringup_dir = os.path.dirname(tests_dir)
        env_dir     = os.path.join(bringup_dir, 'env')
        tmpl_file   = os.path.join(bringup_dir, 'template', 'bringup_wrapper.sv.tmpl')

        if not os.path.isdir(env_dir):
            raise RuntimeError(f"env dir not found: {env_dir}")
        if not os.path.isfile(tmpl_file):
            raise RuntimeError(f"wrapper template not found: {tmpl_file}")

        wrapper = os.path.join(run_dir, f'{testname}.sv')
        with open(tmpl_file, 'r') as f:
            content = f.read()
        content = content.replace('%%TESTNAME%%', testname)
        with open(wrapper, 'w') as f:
            f.write(content)
        emit(f"generated : {wrapper}")

        verilator_top = wrapper
        include_dirs  = [env_dir, tests_dir]
    else:
        tb_dir        = os.path.dirname(tb_file)
        verilator_top = tb_file
        include_dirs  = [tb_dir]

    # Resolve filelist
    tb_dir_for_f = os.path.dirname(tb_file)
    per_test_f   = os.path.join(tb_dir_for_f, f'{testname}.f')
    default_f    = os.path.join(repo_root, 'hdl', 'cpu', 'top', 'cpu.f')

    if os.path.isfile(per_test_f):
        src_f = per_test_f
        emit(f"filelist  : {src_f}  (per-test)")
    elif os.path.isfile(default_f):
        src_f = default_f
        emit(f"filelist  : {src_f}  (default)")
    else:
        raise RuntimeError(
            f"no filelist found for '{testname}'.\n"
            f"  Looked for: {per_test_f}\n"
            f"  Fallback  : {default_f}"
        )

    # Expand path variables and write expanded filelist
    expanded_f = os.path.join(run_dir, 'expanded.f')
    with open(src_f, 'r') as fin, open(expanded_f, 'w') as fout:
        for line in fin:
            fout.write(expand_vars(line))
    emit(f"expanded  : {expanded_f}")

    # Compile with Verilator
    compile_cmd = [
        'verilator',
        '--binary', '--sv', '-Wall', '--timing',
        '-Wno-TIMESCALEMOD', '-Wno-fatal',
    ] + (['--trace'] if trace else []) + (
        ['--threads', str(threads)] if threads > 1 else []
    ) + (extra_verilator_args or []) + [
        '--top-module', testname,
        '--Mdir',       work_dir,
    ] + [f'-I{d}' for d in include_dirs] + [
        '-f',           expanded_f,
        verilator_top,
    ]

    emit('\n--- compile ---')
    emit(' '.join(compile_cmd) + '\n')
    result = run_cmd(compile_cmd)
    if result.returncode != 0:
        raise RuntimeError(f"Verilator compilation failed (exit {result.returncode})")

    # Run simulation
    sim_bin = os.path.join(work_dir, f'V{testname}')
    if not os.access(sim_bin, os.X_OK):
        raise RuntimeError(f"compiled binary not found: {sim_bin}")

    emit('\n--- simulate ---')
    emit(f"cwd: {run_dir}")
    emit(f"{sim_bin}\n")

    result = run_cmd([sim_bin], cwd=run_dir)
    if result.returncode != 0:
        raise RuntimeError(f"Simulation exited with non-zero status ({result.returncode})")

    emit(f"\nOutputs in {run_dir}")

# ---------------------------------------------------------------------------
# Single-test mode
# ---------------------------------------------------------------------------
if not is_regress:
    run_dir = os.path.join(repo_root, 'rundir', args.name)
    try:
        run_test(args.name, run_dir, args.trace, threads=jobs, extra_verilator_args=extra_verilator_args)
    except RuntimeError as e:
        sys.exit(f"ERROR: {e}")

# ---------------------------------------------------------------------------
# Regression mode
# ---------------------------------------------------------------------------
else:
    regressname = args.name

    # Find the .list file under tb/
    list_file = None
    for dirpath, _dirnames, filenames in os.walk(os.path.join(repo_root, 'tb')):
        for fname in filenames:
            if fname == f'{regressname}.list':
                list_file = os.path.join(dirpath, fname)
                break
        if list_file:
            break

    if list_file is None:
        sys.exit(f"ERROR: could not find '{regressname}.list' under {repo_root}/tb  "
                 f"(names starting with regress_ are treated as regression lists)")

    print(f"regression: {list_file}")

    with open(list_file, 'r') as f:
        tests = [line.strip() for line in f if line.strip() and not line.startswith('#')]

    if not tests:
        sys.exit(f"ERROR: no tests found in {list_file}")

    regress_dir = os.path.join(repo_root, 'rundir', regressname)
    os.makedirs(regress_dir, exist_ok=True)

    parallel = jobs > 1
    print_lock = threading.Lock()

    def run_one(testname):
        run_dir  = os.path.join(regress_dir, testname)
        log_path = os.path.join(run_dir, 'run.log')
        os.makedirs(run_dir, exist_ok=True)

        if parallel:
            with print_lock:
                print(f"  START  {testname}")
            try:
                with open(log_path, 'w') as log:
                    run_test(testname, run_dir, args.trace, log=log, extra_verilator_args=extra_verilator_args)
                with print_lock:
                    print(f"  PASS   {testname}")
                return (testname, 'PASS')
            except RuntimeError as e:
                with print_lock:
                    print(f"  FAIL   {testname}  (see {log_path})")
                return (testname, 'FAIL')
        else:
            print(f"\n{'='*60}")
            print(f"Running: {testname}")
            print('='*60)
            try:
                run_test(testname, run_dir, args.trace, extra_verilator_args=extra_verilator_args)
                return (testname, 'PASS')
            except RuntimeError as e:
                print(f"\nERROR: {e}")
                return (testname, 'FAIL')

    if parallel:
        print(f"regression: Running with {jobs} cores\n")
        with concurrent.futures.ThreadPoolExecutor(max_workers=jobs) as executor:
            outcome_list = list(executor.map(run_one, tests))
    else:
        outcome_list = [run_one(t) for t in tests]

    # Preserve original test order in summary
    results = dict(outcome_list)

    print(f"\n{'='*60}")
    print(f"Regression Summary: {regressname}")
    print('='*60)
    for t in tests:
        print(f"  {results[t]}  {t}")

    failed = [t for t in tests if results[t] == 'FAIL']
    if failed:
        sys.exit(f"\n{len(failed)}/{len(tests)} tests FAILED")
    else:
        print(f"\nAll {len(tests)} tests passed.")
