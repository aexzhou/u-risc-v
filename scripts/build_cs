#!/usr/bin/env bash
#
# Build (or rebuild) a ChampSim binary from a config.
#
# Usage: build_cs [config_name]
#   config_name  Name (without .json) under models/cpu/configs/
#                Defaults to uriscv_baseline.
#
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
CHAMPSIM_DIR="$REPO_ROOT/models/cpu/champsim"
CONFIG_DIR="$REPO_ROOT/models/cpu/configs"

config_name="${1:-uriscv_baseline}"
CONFIG="$CONFIG_DIR/${config_name}.json"

if [[ ! -f "$CONFIG" ]]; then
    echo "Error: config not found: $CONFIG" >&2
    echo "Available configs:" >&2
    find "$CONFIG_DIR" -name '*.json' -printf "  %f\n" 2>/dev/null | sed 's/\.json$//' >&2
    exit 1
fi

CONFIG="$(cd "$(dirname "$CONFIG")" && pwd)/$(basename "$CONFIG")"
bin_name="$(python3 -c "import json; print(json.load(open('$CONFIG'))['executable_name'])")"
bin_path="$CHAMPSIM_DIR/bin/$bin_name"

# Clean old binary so we always rebuild
rm -f "$bin_path"

echo "=== Building ChampSim: $config_name ==="
echo "  Config: $CONFIG"

pushd "$CHAMPSIM_DIR" > /dev/null
python3 config.sh "$CONFIG"
make -j"$(nproc)"
popd > /dev/null

echo ""
echo "=== Build complete ==="
echo "Binary: $bin_path"
